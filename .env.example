# ============================
# 에듀플로 환경 설정
# ============================

# ─── 로컬 모드 (개인 사용) ───────────────────────
# true로 설정하면 Google 로그인 없이 바로 사용 가능
# 모든 기능 개방, 프로젝트 99개, 전 모델 허용
LOCAL_MODE=true

# ─── AI API 키 (최소 하나 이상 설정) ────────────────
# 사용하려는 모델의 프로바이더 키만 설정하면 됩니다.

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI GPT (https://platform.openai.com)
# OPENAI_API_KEY=sk-xxx

# Google Gemini (https://aistudio.google.com/apikey)
# GOOGLE_API_KEY=xxx

# Upstage Solar (https://console.upstage.ai)
# UPSTAGE_API_KEY=up_xxx

# ─── 서버 설정 ─────────────────────────────────
PORT=7829
CLIENT_URL=http://localhost:7830
# PROJECTS_DIR=./projects
# TEMPLATES_DIR=./templates

# ─── 아래는 배포 모드 전용 (LOCAL_MODE=true면 불필요) ──

# 구글 로그인
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# JWT_SECRET=your-jwt-secret

# GitHub OAuth (사용자별 배포)
# https://github.com/settings/applications/new 에서 생성
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=/api/auth/github/callback

# 포트폴리오 자동 등록용 서버 토큰
# PORTFOLIO_GITHUB_TOKEN=

# 관리자 이메일 (쉼표 구분)
# ADMIN_EMAILS=admin@example.com
